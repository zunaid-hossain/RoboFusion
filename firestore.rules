rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && 
             request.auth.token.email == 'zunaidhossain39@gmail.com' && 
             request.auth.token.email_verified == true; 
    }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidRegistration(data) {
      return data.keys().hasAll([
        'firstName', 'lastName', 'studentId', 'email', 'phone', 
        'department', 'semester', 'selectedEvents', 'isClubMember', 
        'paymentMethod', 'transactionId', 'totalAmount', 'status', 
        'createdAt', 'updatedAt'
      ]) &&
      data.firstName is string && data.firstName.size() <= 100 &&
      data.lastName is string && data.lastName.size() <= 100 &&
      data.studentId is string && data.studentId.size() <= 50 &&
      data.email is string && data.email.size() <= 100 &&
      data.phone is string && data.phone.size() <= 50 &&
      data.department is string &&
      data.semester is string &&
      data.selectedEvents is list && data.selectedEvents.size() > 0 && data.selectedEvents.size() <= 10 &&
      data.isClubMember is bool &&
      data.paymentMethod is string &&
      data.transactionId is string && data.transactionId.size() <= 100 &&
      data.totalAmount is number &&
      data.status in ['pending', 'confirmed', 'rejected'] &&
      data.createdAt == request.time &&
      data.updatedAt == request.time;
    }

    // --- Registrations ---
    match /registrations/{registrationId} {
      allow create: if isValidRegistration(incoming()) && 
                       incoming().status == 'pending';
      
      allow read, list: if isAdmin();
      
      allow update: if isAdmin() &&
                       incoming().updatedAt == request.time &&
                       incoming().diff(existing()).affectedKeys().hasAny(['status', 'updatedAt']);
                       
      allow delete: if isAdmin();
    }
  }
}
